#: D:\top_speed\top_speed_net\TopSpeed\Menu\Build\Options\Volume.cs:33
msgid "Controls engine-related sounds for bots and other players, including engine start and stop."
msgstr "Điều chỉnh âm thanh động cơ của bot và người chơi khác, bao gồm tiếng nổ máy và tắt máy."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\Build\Options\Volume.cs:28
msgid "Controls events related to your own vehicle, such as horn, back-fire, and other vehicle events."
msgstr "Điều chỉnh các sự kiện liên quan đến xe của chính bạn, chẳng hạn như còi, tiếng nổ pô lụp bụp và các sự kiện khác của xe."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\Build\Options\Volume.cs:38
