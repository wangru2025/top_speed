#: D:\top_speed\top_speed_net\TopSpeed\Menu\Build\Options\Volume.cs:62
msgid "Controls menu and race music volume. This stays synchronized with the menu music volume setting."
msgstr "Điều chỉnh âm lượng nhạc menu và nhạc khi đua. Cài đặt này luôn được đồng bộ với tùy chọn âm lượng nhạc menu."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\Build\Options\Volume.cs:48
